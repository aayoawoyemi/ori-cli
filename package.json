{
  "name": "@orimnemos/cli",
  "version": "2.0.0-preview.0",
  "description": "Memory-native coding agent CLI. Built on Ori Mnemos.",
  "type": "module",
  "bin": {
    "ori": "./dist/index.js"
  },
  "files": [
    "dist",
    "body/_protocol.py",
    "body/codebase.py",
    "body/fs.py",
    "body/indexer.py",
    "body/judgment.py",
    "body/plan.py",
    "body/repl.py",
    "body/research.py",
    "body/rlm.py",
    "body/schema_calibrate.py",
    "body/schema.py",
    "body/scratch.py",
    "body/security.py",
    "body/server.py",
    "body/shape.py",
    "body/shell.py",
    "body/spanner.py",
    "body/speak.py",
    "body/state.py",
    "body/vault.py",
    "body/version.py",
    "body/web.py",
    "body/schema.calibrated.json",
    "body/requirements.txt",
    "body/CODEBASE_CONTRACT.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --watch --watch-path=src --watch-path=body --watch-preserve-output --import tsx src/index.ts",
    "dev:once": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/genai": "^1.0.0",
    "chalk": "^5.4.0",
    "fast-xml-parser": "^5.7.0",
    "glob": "^11.0.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.3.0",
    "ori-memory": "^0.5.5",
    "react": "^19.2.4",
    "xxhash-wasm": "^1.1.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "memory",
    "cli",
    "coding-agent",
    "ori",
    "llm",
    "persistent-memory"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/aayoawoyemi/ori-cli"
  }
}
